{
  "name": "yolo",
  "private": true,
  "scripts": {
    "build": "npm run build:web",
    "build:web": "npm run build --prefix web",
    "build:admin": "npm run build --prefix admin",
    "build:support": "npm run build --prefix web/support",
    "deploy:web": "npm run build:web && wrangler deploy",
    "deploy:admin": "bash scripts/deploy-admin.sh",
    "deploy:support": "npm run build:support && wrangler deploy --config wrangler.support.jsonc"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
