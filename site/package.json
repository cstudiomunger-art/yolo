{
  "name": "yolo-happy-site",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch:visa": "node scripts/fetch-visa-data.mjs",
    "fetch:content": "node scripts/fetch-content-data.mjs",
    "fetch": "npm run fetch:visa && npm run fetch:content",
    "dev": "npm run fetch && astro dev",
    "build": "npm run fetch && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.2.5",
    "sanitize-html": "^2.17.5"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.25.12": true,
    "sharp@0.34.5": true
  }
}
