---
// Generic, reusable micro-tool: checks whether a name is in a shape that China's
// real-name, passport-based ticket systems will accept. Runs fully client-side; no
// per-attraction data needed. Shared by the tickets hub and every attraction page.
---
<div class="pnc card">
  <label class="pnc-label" for="pnc-input">Your name, exactly as printed in your passport</label>
  <input id="pnc-input" class="pnc-input" type="text" autocomplete="off" spellcheck="false"
         placeholder="e.g. SMITH John Michael" />
  <button id="pnc-check" class="btn btn-primary pnc-btn" type="button">Check my name</button>
  <div id="pnc-result" class="pnc-result" role="status" aria-live="polite"></div>
  <p class="pnc-hint ui">We never store or send this — the check runs in your browser.</p>
</div>

<script>
  // Build result with safe DOM construction only — user input is never interpolated into HTML.
  function checkName(): { tone: "ok" | "warn" | "bad"; title: string; notes: string[] } {
    const el = document.getElementById("pnc-input") as HTMLInputElement | null;
    const raw = el?.value ?? "";
    const name = raw.trim();
    const notes: string[] = [];

    if (!name) return { tone: "warn", title: "Type your name to check it.", notes: [] };
    if (/[㐀-鿿぀-ヿ가-힯]/.test(name))
      return {
        tone: "bad",
        title: "Use the Latin spelling from your passport — not Chinese/Japanese/Korean characters.",
        notes: ["Real-name ticketing matches the Latin (pinyin/romanized) name in your passport's data page."],
      };
    if (/\d/.test(name))
      return { tone: "bad", title: "A passport name shouldn't contain digits.", notes: ["Remove any numbers."] };

    if (/[^A-Za-z .,'\-]/.test(name))
      notes.push("Contains unusual characters — keep to letters, spaces, hyphens and apostrophes as in your passport.");
    if (/\s{2,}/.test(raw) || raw !== name)
      notes.push("Extra or leading/trailing spaces can cause a mismatch — use single spaces.");
    if (!name.includes(" "))
      notes.push("Only one word entered — most passports have a surname and given name(s); enter both.");
    if (name.length < 2)
      notes.push("That looks too short to match a passport name.");

    const bad = notes.length > 0;
    return {
      tone: bad ? "warn" : "ok",
      title: bad ? "Close — double-check the points below" : "Looks valid for real-name booking",
      notes: [
        ...notes,
        "Enter the surname and given names in the same order the booking form asks for (China often lists surname first).",
        "It must be identical to your passport — the staff check the physical passport against your ticket at the gate.",
      ],
    };
  }

  function render() {
    const out = document.getElementById("pnc-result");
    if (!out) return;
    const r = checkName();
    out.textContent = "";
    out.className = `pnc-result tone-${r.tone}`;
    const h = document.createElement("p");
    h.className = "pnc-title";
    h.textContent = r.title; // textContent → no HTML injection
    out.appendChild(h);
    if (r.notes.length) {
      const ul = document.createElement("ul");
      for (const n of r.notes) {
        const li = document.createElement("li");
        li.textContent = n;
        ul.appendChild(li);
      }
      out.appendChild(ul);
    }
  }

  document.getElementById("pnc-check")?.addEventListener("click", render);
  document.getElementById("pnc-input")?.addEventListener("keydown", (e) => {
    if ((e as KeyboardEvent).key === "Enter") render();
  });
</script>

<style>
  .pnc { padding: 22px; max-width: 560px; }
  .pnc-label { display: block; font-family: var(--font-ui); font-size: 0.82rem; font-weight: 600; color: var(--ink-soft); margin-bottom: 8px; }
  .pnc-input { width: 100%; font-family: var(--font-ui); font-size: 1rem; letter-spacing: 0.03em; padding: 12px 14px; border: 1px solid var(--border-strong); border-radius: var(--radius-sm); background: var(--surface); color: var(--ink); }
  .pnc-input:focus { outline: none; border-color: var(--coral); box-shadow: 0 0 0 3px var(--coral-tint); }
  .pnc-btn { width: 100%; margin-top: 12px; justify-content: center; }
  .pnc-result:empty { display: none; }
  .pnc-result { margin-top: 16px; padding: 16px; border-radius: var(--radius-sm); border: 1px solid var(--border); }
  .pnc-result.tone-ok { background: var(--green-tint); border-color: #bfe2c8; }
  .pnc-result.tone-warn { background: var(--amber-tint); border-color: #ecd7a6; }
  .pnc-result.tone-bad { background: var(--red-tint); border-color: #eebfb9; }
  .pnc-title { font-family: var(--font-ui); font-weight: 600; margin: 0; color: var(--ink); }
  .pnc-result ul { margin: 8px 0 0; padding-left: 18px; }
  .pnc-result li { font-size: 0.9rem; color: var(--ink-soft); margin: 4px 0; }
  .pnc-hint { font-size: 0.78rem; color: var(--faint); margin: 10px 0 0; }
</style>
