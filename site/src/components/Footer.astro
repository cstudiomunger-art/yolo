---
import { NAV, SITE } from "../lib/site";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand"><span class="brand-mark">YOLO</span> HAPPY</span>
      <p class="muted">{SITE.positioning} We decode China's rules so you can operate the local systems yourself.</p>
    </div>
    <nav class="footer-links ui">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={SITE.appStoreUrl}>Download</a>
    </nav>
  </div>
  <div class="container footer-base ui">
    <span>© {year} {SITE.name}</span>
    <span class="muted">Travel rules change. Always confirm against official sources before you travel.</span>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--border); margin-top: 40px; padding: 48px 0 36px; }
  .footer-inner { display: flex; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .footer-brand { max-width: 40ch; }
  .brand { font-family: var(--font-ui); font-weight: 700; font-size: 1.05rem; }
  .brand-mark { color: var(--coral); }
  .footer-links { display: flex; flex-wrap: wrap; gap: 18px; align-items: flex-start; }
  .footer-links a { color: var(--ink-soft); font-size: 0.92rem; font-weight: 500; }
  .footer-links a:hover { color: var(--coral-dark); }
  .footer-base { display: flex; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 0.82rem; color: var(--faint); }
</style>
