# Security headers for all routes (served by Cloudflare static assets).
# The Content-Security-Policy is emitted per-page as a <meta> tag by Astro (it auto-hashes
# inline scripts/styles). X-Frame-Options covers clickjacking since meta CSP can't set
# frame-ancestors.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
